# Local-only — don't upload to Vercel
venv/
__pycache__/
.git/
.claude/
.DS_Store
.env
*.pyc
*.pyo

# Heavy local data — never deployed. All runtime data comes from Supabase.
data/
output/
graphify-out/
mockups/
~$*
*.xlsx
*.gdb/

# FastAPI app runs only locally for ingestion; not deployed to Vercel.
app.py
keystone_field_api/

# Local-only ingestion scripts
scripts/

# Retired nested config
keystone_field_web/vercel.json

# CRITICAL — local Supabase CLI directory shadows the pip-installed `supabase`
# Python package on Vercel, causing "ImportError: cannot import name
# 'create_client' from 'supabase' (unknown location)". Migrations + edge
# functions are only needed locally for `supabase db push` / `supabase functions deploy`.
supabase/

# Local-only Python deps (geopandas/fiona/shapely/pandas/fastapi/uvicorn).
# Vercel reads the root `requirements.txt` (supabase only) for api/*.py.
requirements-local.txt
