{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "crons": [
    { "path": "/api/daily-refresh", "schedule": "0 4 * * *" },
    { "path": "/api/daily-refresh", "schedule": "0 5 * * *" },
    { "path": "/api/daily-refresh?mode=report", "schedule": "0 0 * * *" },
    { "path": "/api/daily-refresh?mode=report", "schedule": "0 1 * * *" }
  ],
  "functions": {
    "api/upload.py": { "maxDuration": 300 },
    "api/daily-refresh.py": { "maxDuration": 300 }
  },
  "rewrites": [
    { "source": "/",                 "destination": "/keystone_field_web/index" },
    { "source": "/field",            "destination": "/keystone_field_web/index" },
    { "source": "/field/",           "destination": "/keystone_field_web/index" },
    { "source": "/field/:path*",     "destination": "/keystone_field_web/:path*" },
    { "source": "/login",            "destination": "/keystone_field_web/login" },
    { "source": "/admin",            "destination": "/keystone_field_web/admin" },
    { "source": "/dashboard",        "destination": "/static/index.html" },
    { "source": "/dashboard/",       "destination": "/static/index.html" },
    { "source": "/dashboard/:path*", "destination": "/static/:path*" },
    { "source": "/manifest.json",    "destination": "/keystone_field_web/manifest.json" },
    { "source": "/sw.js",            "destination": "/keystone_field_web/sw.js" }
  ],
  "headers": [
    {
      "source": "/keystone_field_web/sw.js",
      "headers": [
        { "key": "Cache-Control",          "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control",          "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control",        "value": "no-store" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/dashboard(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://unpkg.com https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://*.basemaps.cartocdn.com https://*.openstreetmap.org https://*.tile.openstreetmap.org; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.groq.com https://nominatim.openstreetmap.org; worker-src blob:; child-src blob:" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://unpkg.com https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://*.basemaps.cartocdn.com https://*.openstreetmap.org https://*.tile.openstreetmap.org; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.groq.com https://nominatim.openstreetmap.org; worker-src blob:; child-src blob:; manifest-src 'self'" }
      ]
    }
  ]
}
