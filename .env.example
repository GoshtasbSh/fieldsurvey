NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
GMAIL_USER=
GMAIL_APP_PASSWORD=
EMAIL_FROM_NAME=FieldSurvey
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Shared secret protecting the Python /api/py/match-responses serverless.
# The Next.js auth shim at /api/match sets X-Internal-Secret with this
# value; the Python handler rejects any request that doesn't match.
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=

# HMAC key for the guest-mode (`fs_guest`) cookie issued by /api/guest/start.
# A surveyor enters an admin-issued day-code, we validate it, then sign
# {sessionId,projectId,expiresAt} into an httpOnly cookie that subsequent
# /api/points/guest requests re-validate. Must be ≥32 chars.
# Generate with: openssl rand -hex 32
GUEST_COOKIE_SECRET=
