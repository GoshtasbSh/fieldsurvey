# ────────────────────────────────────────────────────────────────────────
# KeyStone — environment variables
# Copy this file to .env and fill in real values. Never commit .env.
# On Vercel, add these under Project Settings → Environment Variables.
# ────────────────────────────────────────────────────────────────────────

# Supabase — required
# Find in Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co

# Anon (public) key — safe to expose to the browser; protected by RLS
SUPABASE_ANON_KEY=eyJhbGci...anon...

# Service role key — SERVER ONLY. Never expose to the browser.
# Used by the backend for bulk ingests that need to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...service_role...

# Groq — required for /api/chat (llama-3.3-70b survey analyst)
GROQ_API_KEY=gsk_...

# Cron authentication — required to secure /api/daily-refresh.
# Set this in Vercel Project Settings → Environment Variables.
# Vercel's scheduler sends this automatically as: Authorization: Bearer <value>
# Without it, the nightly refresh cron is permanently blocked (returns 401).
CRON_SECRET=your-random-secret-here

# Daily report recipient (seeded into report_config on first migration)
KEYSTONE_REPORT_EMAIL=you@example.com

# Optional — US Census Geocoder has no key; Nominatim has no key
# (fields left here for future use)
# CENSUS_API_KEY=
